<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Signal">
<meta name="theme-color" content="#0F0E0C">
<title>Save Signal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Libre+Baskerville:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<!-- PWA manifest inline -->
<script>
  // Register inline manifest as a blob
  const manifest = {
    name: "Save Signal",
    short_name: "Signal",
    start_url: "/save",
    display: "standalone",
    background_color: "#0F0E0C",
    theme_color: "#0F0E0C",
    icons: [
      { src: "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'><rect width='192' height='192' fill='%230F0E0C'/><text y='140' x='20' font-size='130' font-family='serif'>⚡</text></svg>", sizes: "192x192", type: "image/svg+xml" }
    ]
  };
  const blob = new Blob([JSON.stringify(manifest)], {type: 'application/json'});
  const manifestURL = URL.createObjectURL(blob);
  document.addEventListener('DOMContentLoaded', () => {
    const link = document.createElement('link');
    link.rel = 'manifest';
    link.href = manifestURL;
    document.head.appendChild(link);
  });
</script>

<style>
  :root {
    --bg: #0F0E0C;
    --sur: #1A1916;
    --sur2: #242220;
    --bor: #2E2C28;
    --bor2: #3D3A35;
    --txt: #F2EFE8;
    --txt2: #9C9890;
    --txt3: #5C5A55;
    --gold: #C8A96A;
    --green: #4A9A6A;
    --red: #C84B2F;
    --mono: 'DM Mono', monospace;
    --serif: 'Libre Baskerville', serif;
    --sans: 'DM Sans', sans-serif;
    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bottom: env(safe-area-inset-bottom, 0px);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--txt);
    font-family: var(--sans);
    overflow: hidden;
  }

  .app {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-top: calc(var(--safe-top) + 12px);
    padding-bottom: calc(var(--safe-bottom) + 12px);
    padding-left: 20px;
    padding-right: 20px;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Header */
  .hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-shrink: 0;
  }
  .hdr-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hdr-icon {
    width: 32px;
    height: 32px;
    background: var(--gold);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .hdr-title {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--txt);
  }
  .hdr-sub {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--txt3);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-top: 1px;
  }
  .settings-btn {
    background: none;
    border: 1px solid var(--bor);
    border-radius: 6px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    color: var(--txt3);
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .15s;
  }
  .settings-btn:hover, .settings-btn:active { background: var(--sur2); color: var(--txt); }

  /* Form */
  .form { display: flex; flex-direction: column; gap: 14px; flex: 1; }

  .field { display: flex; flex-direction: column; gap: 6px; }
  .field-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--txt3);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .field-optional {
    font-size: 9px;
    color: var(--txt3);
    letter-spacing: 0;
    text-transform: none;
  }

  input[type="url"],
  input[type="text"],
  textarea {
    background: var(--sur);
    border: 1px solid var(--bor);
    border-radius: 8px;
    color: var(--txt);
    font-family: var(--mono);
    font-size: 13px;
    padding: 12px 14px;
    width: 100%;
    outline: none;
    transition: border-color .15s;
    -webkit-appearance: none;
    appearance: none;
    line-height: 1.5;
  }
  input[type="url"]:focus,
  input[type="text"]:focus,
  textarea:focus {
    border-color: var(--gold);
  }
  input::placeholder, textarea::placeholder {
    color: var(--txt3);
  }
  textarea {
    resize: none;
    min-height: 80px;
  }

  /* Tag chips */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }
  .tag-chip {
    font-family: var(--mono);
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid var(--bor);
    background: var(--sur);
    color: var(--txt2);
    cursor: pointer;
    transition: all .12s;
    user-select: none;
    -webkit-user-select: none;
  }
  .tag-chip.selected {
    background: var(--gold);
    border-color: var(--gold);
    color: #0F0E0C;
  }
  .tag-chip:active { transform: scale(.95); }

  /* Save button */
  .save-btn {
    background: var(--gold);
    color: #0F0E0C;
    border: none;
    border-radius: 10px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: .05em;
    padding: 16px;
    cursor: pointer;
    width: 100%;
    transition: all .15s;
    margin-top: auto;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }
  .save-btn:active { transform: scale(.98); opacity: .9; }
  .save-btn:disabled {
    background: var(--sur2);
    color: var(--txt3);
    cursor: default;
    transform: none;
  }
  .save-btn .btn-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: opacity .2s;
  }

  /* Status toast */
  .toast {
    position: fixed;
    bottom: calc(var(--safe-bottom) + 24px);
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--sur2);
    border: 1px solid var(--bor2);
    border-radius: 10px;
    padding: 12px 20px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--txt);
    white-space: nowrap;
    opacity: 0;
    transition: all .25s cubic-bezier(.4,0,.2,1);
    pointer-events: none;
    z-index: 100;
    max-width: calc(100vw - 40px);
    text-align: center;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .toast.success { border-color: var(--green); color: #6DCC94; }
  .toast.error { border-color: var(--red); color: #E8896A; }

  /* Settings panel */
  .settings-panel {
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 50;
    display: flex;
    flex-direction: column;
    padding: calc(var(--safe-top) + 16px) 20px calc(var(--safe-bottom) + 20px);
    transform: translateY(100%);
    transition: transform .3s cubic-bezier(.4,0,.2,1);
    max-width: 480px;
    margin: 0 auto;
  }
  .settings-panel.open { transform: translateY(0); }
  .settings-hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }
  .settings-title {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 700;
  }
  .close-btn {
    background: none;
    border: 1px solid var(--bor);
    border-radius: 6px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    color: var(--txt2);
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .settings-note {
    font-size: 12px;
    color: var(--txt3);
    line-height: 1.6;
    margin-bottom: 20px;
    font-family: var(--mono);
  }
  .save-settings-btn {
    background: var(--sur2);
    border: 1px solid var(--bor2);
    border-radius: 8px;
    color: var(--txt);
    font-family: var(--mono);
    font-size: 12px;
    padding: 12px;
    cursor: pointer;
    width: 100%;
    margin-top: 16px;
    transition: all .15s;
  }
  .save-settings-btn:active { background: var(--bor); }

  /* Recent saves list */
  .recent-section {
    margin-top: 16px;
    flex-shrink: 0;
  }
  .recent-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--txt3);
    margin-bottom: 8px;
  }
  .recent-item {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--txt3);
    padding: 5px 0;
    border-bottom: 1px solid var(--bor);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .recent-item:last-child { border-bottom: none; }

  /* Spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner {
    width: 14px;
    height: 14px;
    border: 2px solid rgba(0,0,0,.2);
    border-top-color: #0F0E0C;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    flex-shrink: 0;
  }

  /* Pulse on save */
  @keyframes pulse-gold {
    0% { box-shadow: 0 0 0 0 rgba(200,169,106,.4); }
    70% { box-shadow: 0 0 0 12px rgba(200,169,106,0); }
    100% { box-shadow: 0 0 0 0 rgba(200,169,106,0); }
  }
  .save-btn.saving { animation: pulse-gold 1s infinite; }
</style>
</head>
<body>

<div class="app" id="app">
  <div class="hdr">
    <div class="hdr-left">
      <div class="hdr-icon">⚡</div>
      <div>
        <div class="hdr-title">Save Signal</div>
        <div class="hdr-sub">Weak Signal Tracker</div>
      </div>
    </div>
    <button class="settings-btn" onclick="openSettings()" title="Settings">⚙</button>
  </div>

  <div class="form">
    <!-- URL field -->
    <div class="field">
      <div class="field-label">
        URL
        <button onclick="pasteURL()" style="background:none;border:none;cursor:pointer;font-family:var(--mono);font-size:9px;color:var(--gold);letter-spacing:.05em;">Paste ↓</button>
      </div>
      <input type="url" id="url-input" placeholder="https://…" autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false">
    </div>

    <!-- Note field -->
    <div class="field">
      <div class="field-label">
        Note
        <span class="field-optional">optional — leave blank to use headline</span>
      </div>
      <textarea id="note-input" placeholder="Why does this matter as a weak signal?"></textarea>
    </div>

    <!-- Quick tags -->
    <div class="field">
      <div class="field-label">Quick tags <span class="field-optional">optional</span></div>
      <div class="tag-row" id="tag-row">
        <span class="tag-chip" onclick="toggleTag(this)">AI</span>
        <span class="tag-chip" onclick="toggleTag(this)">Politics</span>
        <span class="tag-chip" onclick="toggleTag(this)">Economy</span>
        <span class="tag-chip" onclick="toggleTag(this)">Technology</span>
        <span class="tag-chip" onclick="toggleTag(this)">Society</span>
        <span class="tag-chip" onclick="toggleTag(this)">Environment</span>
        <span class="tag-chip" onclick="toggleTag(this)">Media</span>
        <span class="tag-chip" onclick="toggleTag(this)">Labor</span>
        <span class="tag-chip" onclick="toggleTag(this)">Health</span>
        <span class="tag-chip" onclick="toggleTag(this)">Education</span>
      </div>
    </div>

    <!-- Save button -->
    <button class="save-btn" id="save-btn" onclick="saveSignal()">
      <div class="btn-inner" id="btn-inner">
        <span>Save Signal</span>
      </div>
    </button>

    <!-- Recent saves -->
    <div class="recent-section" id="recent-section" style="display:none;">
      <div class="recent-label">Recently saved</div>
      <div id="recent-list"></div>
    </div>
  </div>
</div>

<!-- Settings panel -->
<div class="settings-panel" id="settings-panel">
  <div class="settings-hdr">
    <div class="settings-title">Settings</div>
    <button class="close-btn" onclick="closeSettings()">✕</button>
  </div>
  <p class="settings-note">Enter your Apps Script Web App URL and secret token. These are saved locally on your device only.</p>
  <div class="field">
    <div class="field-label">Apps Script URL</div>
    <input type="url" id="setting-url" placeholder="https://script.google.com/macros/s/…/exec" autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false">
  </div>
  <div class="field" style="margin-top:14px;">
    <div class="field-label">Secret token</div>
    <input type="text" id="setting-token" placeholder="your-secret-token" autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false">
  </div>
  <button class="save-settings-btn" onclick="saveSettings()">Save settings</button>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ── Config stored in localStorage ──────────────────────────────
const STORAGE_KEY = 'weaksig_save_config';
const RECENT_KEY = 'weaksig_recent_saves';

function getConfig() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; }
  catch(e) { return {}; }
}
function setConfig(cfg) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(cfg));
}

// ── Settings ───────────────────────────────────────────────────
function openSettings() {
  const cfg = getConfig();
  document.getElementById('setting-url').value = cfg.webAppUrl || '';
  document.getElementById('setting-token').value = cfg.token || '';
  document.getElementById('settings-panel').classList.add('open');
}
function closeSettings() {
  document.getElementById('settings-panel').classList.remove('open');
}
function saveSettings() {
  const url = document.getElementById('setting-url').value.trim();
  const token = document.getElementById('setting-token').value.trim();
  if (!url || !token) { showToast('Please enter both URL and token', 'error'); return; }
  setConfig({ webAppUrl: url, token });
  closeSettings();
  showToast('Settings saved ✓', 'success');
}

// ── Tag selection ───────────────────────────────────────────────
function toggleTag(el) {
  el.classList.toggle('selected');
}
function getSelectedTags() {
  return [...document.querySelectorAll('.tag-chip.selected')]
    .map(el => el.textContent.trim())
    .join(', ');
}

// ── Paste helper ────────────────────────────────────────────────
async function pasteURL() {
  try {
    const text = await navigator.clipboard.readText();
    if (text && (text.startsWith('http://') || text.startsWith('https://'))) {
      document.getElementById('url-input').value = text;
      showToast('URL pasted', 'success');
    } else {
      showToast('No URL found in clipboard', 'error');
    }
  } catch(e) {
    // Fallback — just focus the field so they can paste manually
    document.getElementById('url-input').focus();
    showToast('Tap and hold to paste', '');
  }
}

// ── Save signal ────────────────────────────────────────────────
async function saveSignal() {
  const cfg = getConfig();
  if (!cfg.webAppUrl || !cfg.token) {
    showToast('Set up your Apps Script URL first ⚙', 'error');
    openSettings();
    return;
  }

  const url = document.getElementById('url-input').value.trim();
  if (!url) { showToast('Please enter a URL', 'error'); return; }
  if (!url.startsWith('http')) { showToast('URL must start with http', 'error'); return; }

  const note = document.getElementById('note-input').value.trim();
  const tags = getSelectedTags();
  const fullNote = [note, tags].filter(Boolean).join(' | ');

  // Set loading state
  const btn = document.getElementById('save-btn');
  const btnInner = document.getElementById('btn-inner');
  btn.disabled = true;
  btn.classList.add('saving');
  btnInner.innerHTML = '<div class="spinner"></div><span>Saving…</span>';

  try {
    const params = new URLSearchParams({
      token: cfg.token,
      url: url,
      title: '',
      note: fullNote
    });
    const requestUrl = cfg.webAppUrl + '?' + params.toString();

    // Use no-cors mode to avoid CORS issues with Apps Script
    const response = await fetch(requestUrl, {
      method: 'GET',
      mode: 'no-cors'
    });

    // With no-cors we can't read the response body, but if fetch didn't throw we assume success
    onSaveSuccess(url);

  } catch(e) {
    onSaveError(e.message);
  }
}

function onSaveSuccess(url) {
  // Reset form
  document.getElementById('url-input').value = '';
  document.getElementById('note-input').value = '';
  document.querySelectorAll('.tag-chip.selected').forEach(t => t.classList.remove('selected'));

  // Save to recent list
  saveToRecent(url);

  // Reset button
  resetBtn();
  showToast('Signal saved ✓', 'success');

  // Brief visual confirmation
  document.getElementById('save-btn').style.background = '#4A9A6A';
  setTimeout(() => {
    document.getElementById('save-btn').style.background = '';
  }, 800);
}

function onSaveError(msg) {
  resetBtn();
  showToast('Save failed — check settings', 'error');
  console.error('Save error:', msg);
}

function resetBtn() {
  const btn = document.getElementById('save-btn');
  const btnInner = document.getElementById('btn-inner');
  btn.disabled = false;
  btn.classList.remove('saving');
  btnInner.innerHTML = '<span>Save Signal</span>';
}

// ── Recent saves ───────────────────────────────────────────────
function saveToRecent(url) {
  try {
    const recent = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
    recent.unshift({ url, savedAt: new Date().toISOString() });
    localStorage.setItem(RECENT_KEY, JSON.stringify(recent.slice(0, 5)));
    renderRecent();
  } catch(e) {}
}

function renderRecent() {
  try {
    const recent = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
    const section = document.getElementById('recent-section');
    const list = document.getElementById('recent-list');
    if (!recent.length) { section.style.display = 'none'; return; }
    section.style.display = 'block';
    list.innerHTML = recent.map(r => {
      const domain = r.url.replace(/https?:\/\/(www\.)?/, '').split('/')[0];
      const time = new Date(r.savedAt).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
      return `<div class="recent-item">${domain} · ${time}</div>`;
    }).join('');
  } catch(e) {}
}

// ── Toast ──────────────────────────────────────────────────────
let toastTimer = null;
function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + (type || '');
  void t.offsetWidth; // force reflow
  t.classList.add('show');
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

// ── URL from query string (for Share Sheet integration) ────────
// If opened from a Shortcut or Share Sheet with ?url=... pre-fill it
function checkURLParam() {
  const params = new URLSearchParams(window.location.search);
  const incomingUrl = params.get('url');
  if (incomingUrl) {
    document.getElementById('url-input').value = decodeURIComponent(incomingUrl);
    // Clean the URL bar so it doesn't show the params
    window.history.replaceState({}, '', window.location.pathname);
  }
}

// ── Init ───────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  checkURLParam();
  renderRecent();

  // Show settings prompt if not configured
  const cfg = getConfig();
  if (!cfg.webAppUrl || !cfg.token) {
    setTimeout(() => {
      showToast('Tap ⚙ to set up your Apps Script URL', '');
    }, 600);
  }

  // Allow Enter in URL field to move to note
  document.getElementById('url-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      e.preventDefault();
      document.getElementById('note-input').focus();
    }
  });

  // Allow Cmd+Enter to save
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      saveSignal();
    }
  });
});
</script>
</body>
</html>
